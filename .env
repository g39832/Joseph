# ============================================================
# JOSEPH AI Assistant - Environment Configuration
# Copy this file and rename to .env — never commit .env to git
# ============================================================

# --- Ollama Settings ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_FALLBACK_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# --- Assistant Identity ---
JOSEPH_NAME=Joseph
USER_NAME=Boss

# --- Memory Settings ---
MEMORY_DB_PATH=./data/memory.db
CHROMA_DB_PATH=./data/chroma
SHORT_TERM_LIMIT=8

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/joseph.log

# --- API Server ---
API_HOST=127.0.0.1
API_PORT=8000

# --- Voice (Phase 2) ---
WAKE_WORD=joseph
MIC_DEVICE_INDEX=0
WHISPER_MODEL=small.en
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# --- Spotify (optional) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Safety ---
REQUIRE_CONFIRMATION_FOR_SHELL=true
REQUIRE_CONFIRMATION_FOR_FILES=true
REQUIRE_CONFIRMATION_FOR_EMAIL=true
